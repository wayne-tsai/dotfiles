#!/usr/bin/env bash
# update-system — Full apt update, upgrade, dist-upgrade, and cleanup.
# Usage: update-system [--yes]
#
# With --yes all prompts are answered automatically (useful in scripts).
# Without --yes, apt will ask for confirmation as usual.

set -euo pipefail

# ── Colour helpers ────────────────────────────────────────────────────────────
if [[ -t 1 ]]; then
    RED='\033[0;31m'; GREEN='\033[0;32m'
    YELLOW='\033[1;33m'; CYAN='\033[0;36m'
    BOLD='\033[1m'; RESET='\033[0m'
else
    RED=''; GREEN=''; YELLOW=''; CYAN=''; BOLD=''; RESET=''
fi

info()    { echo -e "${CYAN}==>${RESET} ${BOLD}$*${RESET}"; }
success() { echo -e "${GREEN}✔${RESET}  $*"; }
warn()    { echo -e "${YELLOW}⚠${RESET}  $*"; }
die()     { echo -e "${RED}✖${RESET}  $*" >&2; exit 1; }

# ── Sanity checks ─────────────────────────────────────────────────────────────
command -v apt &>/dev/null || die "apt not found — this script targets Debian/Ubuntu."
[[ "$EUID" -eq 0 ]] || { warn "Not root — prepending sudo."; SUDO="sudo"; }
SUDO="${SUDO:-}"

APT_FLAGS=()
[[ "${1:-}" == "--yes" ]] && APT_FLAGS=(-y)

# ── Steps ─────────────────────────────────────────────────────────────────────
info "Updating package lists…"
$SUDO apt update

info "Upgrading installed packages…"
$SUDO apt upgrade "${APT_FLAGS[@]}"

info "Running dist-upgrade (kernel & held packages)…"
$SUDO apt dist-upgrade "${APT_FLAGS[@]}"

info "Removing orphaned packages…"
$SUDO apt autoremove "${APT_FLAGS[@]}"

info "Cleaning package cache…"
$SUDO apt clean

success "System is up to date."

# Prompt to reboot if a kernel update is pending
if [[ -f /var/run/reboot-required ]]; then
    warn "A reboot is required to apply kernel updates."
    read -rp "Reboot now? [y/N] " ans
    [[ "$ans" =~ ^[Yy]$ ]] && $SUDO reboot
fi
