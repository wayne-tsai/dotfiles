#!/usr/bin/env bash
# gen-ssh-key — Generate a new ed25519 SSH keypair with a sensible comment.
#
# Usage: gen-ssh-key [comment]   (defaults to user@hostname)

set -euo pipefail

COMMENT="${1:-$(whoami)@$(hostname -s)}"
KEY_FILE="$HOME/.ssh/id_ed25519"

if [[ -f "$KEY_FILE" ]]; then
    echo "Key already exists at $KEY_FILE"
    echo "Public key:"
    cat "${KEY_FILE}.pub"
    exit 0
fi

install -d -m 700 "$HOME/.ssh"
ssh-keygen -t ed25519 -C "$COMMENT" -f "$KEY_FILE"

echo ""
echo "Public key (copy this to authorized_keys / GitHub / etc.):"
cat "${KEY_FILE}.pub"
