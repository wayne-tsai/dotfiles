#!/usr/bin/env bash
# add-authorized-key — Safely append a public key to ~/.ssh/authorized_keys.
#
# Usage:
#   add-authorized-key <pubkey-file>      # from a local .pub file
#   add-authorized-key "<key-string>"     # paste the key inline
#   echo "<key>" | add-authorized-key -   # pipe from stdin
#
# Safety:
#   - Always APPENDS; never overwrites existing keys.
#   - Checks for duplicate keys before appending.
#   - Sets correct permissions: 700 on ~/.ssh, 600 on authorized_keys.
#   - The caller must already be authenticated to this machine; this script
#     only manages which other keys may connect in the future.

set -euo pipefail

# ── Colour helpers ────────────────────────────────────────────────────────────
if [[ -t 1 ]]; then
    RED='\033[0;31m'; GREEN='\033[0;32m'
    YELLOW='\033[1;33m'; CYAN='\033[0;36m'
    BOLD='\033[1m'; RESET='\033[0m'
else
    RED=''; GREEN=''; YELLOW=''; CYAN=''; BOLD=''; RESET=''
fi

info()    { echo -e "${CYAN}==>${RESET} ${BOLD}$*${RESET}"; }
success() { echo -e "${GREEN}✔${RESET}  $*"; }
warn()    { echo -e "${YELLOW}⚠${RESET}  $*"; }
die()     { echo -e "${RED}✖${RESET}  $*" >&2; exit 1; }

# ── Read the key ──────────────────────────────────────────────────────────────
if [[ $# -eq 0 ]]; then
    die "Usage: add-authorized-key <pubkey-file | key-string | ->"
fi

ARG="$1"

if [[ "$ARG" == "-" ]]; then
    PUBKEY="$(cat)"
elif [[ -f "$ARG" ]]; then
    PUBKEY="$(cat "$ARG")"
else
    PUBKEY="$ARG"
fi

# Strip leading/trailing whitespace
PUBKEY="$(echo "$PUBKEY" | xargs)"

# ── Validate it looks like an SSH public key ──────────────────────────────────
if ! echo "$PUBKEY" | grep -qE '^(ssh-(rsa|ed25519|ecdsa|dss)|ecdsa-sha2-nistp(256|384|521))'; then
    die "Input does not look like an SSH public key: ${PUBKEY:0:60}…"
fi

# ── Set up ~/.ssh ─────────────────────────────────────────────────────────────
SSH_DIR="$HOME/.ssh"
AUTH_KEYS="$SSH_DIR/authorized_keys"

install -d -m 700 "$SSH_DIR"
touch "$AUTH_KEYS"
chmod 600 "$AUTH_KEYS"

# ── Check for duplicates ──────────────────────────────────────────────────────
# Compare on the key material (2nd field) only, ignoring comment differences.
KEY_MATERIAL="$(echo "$PUBKEY" | awk '{print $1, $2}')"

if grep -qF "$KEY_MATERIAL" "$AUTH_KEYS" 2>/dev/null; then
    warn "Key already present in $AUTH_KEYS — nothing to do."
    exit 0
fi

# ── Append ────────────────────────────────────────────────────────────────────
echo "$PUBKEY" >> "$AUTH_KEYS"
success "Key appended to $AUTH_KEYS"

# Confirm permissions once more
chmod 700 "$SSH_DIR"
chmod 600 "$AUTH_KEYS"

# ── Show summary ──────────────────────────────────────────────────────────────
KEY_TYPE="$(echo "$PUBKEY" | awk '{print $1}')"
KEY_COMMENT="$(echo "$PUBKEY" | awk '{print $3}')"
info "Type   : $KEY_TYPE"
info "Comment: ${KEY_COMMENT:-(none)}"
info "Total keys in authorized_keys: $(grep -c '^[^#]' "$AUTH_KEYS" 2>/dev/null || echo 0)"
